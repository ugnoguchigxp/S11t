{
  "name": "@s11t/cli",
  "version": "0.0.0",
  "description": "TOML authoring and build CLI for S11t",
  "type": "module",
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ugnoguchigxp/S11t.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ugnoguchigxp/S11t/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/ugnoguchigxp/S11t/issues"
  },
  "files": ["bin", "dist", "README.md", "LICENSE", "NOTICE", "SECURITY.md", "CONTRIBUTING.md", "CHANGELOG.md"],
  "bin": {
    "s11t": "./bin/s11t.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || ^22.0.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@s11t/runtime": "workspace:*",
    "smol-toml": "1.7.0"
  }
}

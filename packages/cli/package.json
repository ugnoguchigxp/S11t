{
  "name": "s11tnext-cli",
  "version": "0.1.0",
  "description": "TOML authoring and build CLI for S11tnext",
  "keywords": [
    "llm",
    "prompt",
    "system-context",
    "prompt-management",
    "cli"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ugnoguchigxp/s11tnext.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ugnoguchigxp/s11tnext/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/ugnoguchigxp/s11tnext/issues"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "bin": {
    "s11tnext": "./bin/s11tnext.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || ^22.0.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b --pretty false && node ../../scripts/bundle-packages.mjs cli",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "s11tnext": "workspace:*",
    "smol-toml": "1.7.0"
  }
}

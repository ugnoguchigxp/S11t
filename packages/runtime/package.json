{
  "name": "s11tnext",
  "version": "0.0.0",
  "description": "Filesystem-independent runtime and compiler contracts for S11tnext",
  "keywords": ["llm", "prompt", "system-context", "prompt-management", "typescript"],
  "type": "module",
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ugnoguchigxp/s11tnext.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/ugnoguchigxp/s11tnext/tree/main/packages/runtime#readme",
  "bugs": {
    "url": "https://github.com/ugnoguchigxp/s11tnext/issues"
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler.d.ts",
      "import": "./dist/compiler.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || ^22.0.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b --pretty false && node ../../scripts/bundle-packages.mjs runtime",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:no-node-builtins": "node ../../scripts/check-runtime-boundary.mjs",
    "test:browser-bundle": "node ../../scripts/check-browser-bundle.mjs"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0"
  }
}

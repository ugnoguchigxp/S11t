{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s11t.dev/schemas/s11t-artifact-v1.schema.json",
  "title": "S11t catalog artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "compilerVersion",
    "defaultLocale",
    "createdFrom",
    "contexts",
    "catalogDigest"
  ],
  "properties": {
    "format": { "const": "s11t.catalog" },
    "schemaVersion": { "const": 1 },
    "compilerVersion": { "type": "string", "minLength": 1 },
    "defaultLocale": { "type": "string", "minLength": 1 },
    "createdFrom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["configPath", "sourceFiles"],
      "properties": {
        "configPath": { "$ref": "#/$defs/relativePath" },
        "sourceFiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/relativePath" }
        }
      }
    },
    "contexts": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/context" }
    },
    "catalogDigest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "type", "trust", "placement", "encoding"],
      "properties": {
        "required": { "const": true },
        "type": { "enum": ["string", "number", "boolean", "json"] },
        "trust": { "enum": ["trusted", "untrusted"] },
        "placement": { "enum": ["inline", "delimited-context"] },
        "encoding": { "enum": ["raw", "json-string", "json-value"] }
      },
      "allOf": [
        {
          "not": {
            "required": ["trust", "encoding"],
            "properties": {
              "trust": { "const": "untrusted" },
              "encoding": { "const": "raw" }
            }
          }
        },
        {
          "if": { "required": ["encoding"], "properties": { "encoding": { "const": "raw" } } },
          "then": { "required": ["type"], "properties": { "type": { "const": "string" } } }
        },
        {
          "if": { "required": ["encoding"], "properties": { "encoding": { "const": "json-string" } } },
          "then": { "required": ["type"], "properties": { "type": { "enum": ["string", "number", "boolean"] } } }
        }
      ]
    },
    "segment": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "literal" },
            "value": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "name"],
          "properties": {
            "type": { "const": "variable" },
            "name": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "severity", "enforcement", "optimizable", "segments"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["instruction", "runtime-fact", "tool-contract", "output-contract", "overlay"]
        },
        "severity": { "enum": ["must", "should", "may"] },
        "enforcement": { "enum": ["prompt", "schema", "host"] },
        "optimizable": { "type": "boolean" },
        "segments": {
          "type": "array",
          "items": { "$ref": "#/$defs/segment" }
        }
      }
    },
    "locale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections", "artifactHash"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/section" }
        },
        "artifactHash": { "$ref": "#/$defs/digest" }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "owner",
        "output",
        "sourceLocale",
        "requiredLocales",
        "variables",
        "locales",
        "definitionHash",
        "releaseDigest"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "output": { "const": "text" },
        "sourceLocale": { "type": "string", "minLength": 1 },
        "requiredLocales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "variables": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/variable" }
        },
        "locales": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/locale" }
        },
        "definitionHash": { "$ref": "#/$defs/digest" },
        "releaseDigest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}

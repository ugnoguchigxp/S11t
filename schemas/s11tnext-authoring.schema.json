{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s11tnext.dev/schemas/s11tnext-authoring.schema.json",
  "title": "S11tnext content-first TOML authoring document",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "content_kind": { "const": "text" },
    "message_role": { "enum": ["system", "user"] },
    "source_locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$"
    },
    "text": { "type": "string", "minLength": 1 },
    "translations": { "$ref": "#/$defs/translations" },
    "variables": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z][A-Za-z0-9_]*$" },
      "additionalProperties": { "$ref": "#/$defs/variable" }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "oneOf": [
    {
      "required": ["text"],
      "properties": { "text": {}, "sections": false }
    },
    {
      "required": ["sections"],
      "properties": { "sections": {}, "text": false, "translations": false }
    }
  ],
  "$defs": {
    "translation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": { "text": { "type": "string", "minLength": 1 } }
    },
    "translations": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$" },
      "additionalProperties": { "$ref": "#/$defs/translation" }
    },
    "variable": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile"],
          "properties": {
            "profile": { "type": "string", "minLength": 1 },
            "required": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "trust", "placement", "encoding"],
          "properties": {
            "required": { "type": "boolean" },
            "type": { "enum": ["string", "number", "boolean", "json"] },
            "trust": { "enum": ["trusted", "untrusted"] },
            "placement": { "enum": ["inline", "delimited-context"] },
            "encoding": { "enum": ["raw", "delimited-text", "json-string", "json-value"] }
          },
          "allOf": [
            {
              "not": {
                "required": ["trust", "encoding"],
                "properties": {
                  "trust": { "const": "untrusted" },
                  "encoding": { "const": "raw" }
                }
              }
            },
            {
              "if": { "properties": { "encoding": { "const": "raw" } }, "required": ["encoding"] },
              "then": { "properties": { "type": { "const": "string" } }, "required": ["type"] }
            },
            {
              "if": { "properties": { "encoding": { "const": "json-string" } }, "required": ["encoding"] },
              "then": { "properties": { "type": { "enum": ["string", "number", "boolean"] } }, "required": ["type"] }
            },
            {
              "if": { "properties": { "encoding": { "const": "delimited-text" } }, "required": ["encoding"] },
              "then": {
                "properties": {
                  "type": { "const": "string" },
                  "placement": { "const": "delimited-context" }
                },
                "required": ["type", "placement"]
              }
            },
            {
              "if": { "properties": { "trust": { "const": "untrusted" } }, "required": ["trust"] },
              "then": { "properties": { "placement": { "const": "delimited-context" } }, "required": ["placement"] }
            }
          ]
        }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "profile": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["instruction", "runtime-fact", "tool-contract", "output-contract", "overlay"] },
        "severity": { "enum": ["must", "should", "may"] },
        "optimizable": { "type": "boolean" },
        "omit_if_empty": { "type": "boolean" },
        "text": { "type": "string", "minLength": 1 },
        "translations": { "$ref": "#/$defs/translations" }
      },
      "oneOf": [
        {
          "required": ["profile"],
          "properties": {
            "profile": {},
            "kind": false,
            "severity": false,
            "optimizable": false
          }
        },
        {
          "required": ["kind", "severity", "optimizable"],
          "properties": {
            "profile": false,
            "kind": {},
            "severity": {},
            "optimizable": {}
          }
        }
      ]
    }
  }
}

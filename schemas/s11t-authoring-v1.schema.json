{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s11t.dev/schemas/s11t-authoring-v1.schema.json",
  "title": "S11t TOML authoring document v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "context"],
  "properties": {
    "schema_version": { "const": 1 },
    "context": { "$ref": "#/$defs/context" },
    "variables": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z][A-Za-z0-9_]*$" },
      "additionalProperties": { "$ref": "#/$defs/variable" }
    },
    "locales": { "$ref": "#/$defs/localeMap" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "oneOf": [
    {
      "required": ["locales"],
      "properties": { "locales": {}, "sections": false }
    },
    {
      "required": ["sections"],
      "properties": { "sections": {}, "locales": false }
    }
  ],
  "$defs": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "owner", "source_locale", "required_locales", "output"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*:[A-Za-z][A-Za-z0-9_.-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
        },
        "owner": { "type": "string", "minLength": 1 },
        "source_locale": { "$ref": "#/$defs/localeName" },
        "required_locales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/localeName" }
        },
        "output": { "const": "text" }
      }
    },
    "localeName": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$"
    },
    "localeMap": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/localeName" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": { "text": { "type": "string", "minLength": 1 } }
      }
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "type", "trust", "placement", "encoding"],
      "properties": {
        "required": { "const": true },
        "type": { "enum": ["string", "number", "boolean", "json"] },
        "trust": { "enum": ["trusted", "untrusted"] },
        "placement": { "enum": ["inline", "delimited-context"] },
        "encoding": { "enum": ["raw", "json-string", "json-value"] }
      },
      "allOf": [
        {
          "not": {
            "required": ["trust", "encoding"],
            "properties": {
              "trust": { "const": "untrusted" },
              "encoding": { "const": "raw" }
            }
          }
        },
        {
          "if": { "required": ["encoding"], "properties": { "encoding": { "const": "raw" } } },
          "then": { "required": ["type"], "properties": { "type": { "const": "string" } } }
        },
        {
          "if": { "required": ["encoding"], "properties": { "encoding": { "const": "json-string" } } },
          "then": { "required": ["type"], "properties": { "type": { "enum": ["string", "number", "boolean"] } } }
        }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "severity", "enforcement", "optimizable", "locales"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["instruction", "runtime-fact", "tool-contract", "output-contract", "overlay"]
        },
        "severity": { "enum": ["must", "should", "may"] },
        "enforcement": { "enum": ["prompt", "schema", "host"] },
        "optimizable": { "type": "boolean" },
        "locales": { "$ref": "#/$defs/localeMap" }
      }
    }
  }
}

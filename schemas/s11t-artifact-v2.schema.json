{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s11t.dev/schemas/s11t-artifact-v2.schema.json",
  "title": "S11t catalog artifact v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "compilerVersion",
    "releaseProfile",
    "policyDigest",
    "createdFrom",
    "contexts",
    "aliases",
    "catalogDigest"
  ],
  "properties": {
    "format": { "const": "s11t.catalog" },
    "schemaVersion": { "const": 2 },
    "compilerVersion": { "type": "string", "minLength": 1 },
    "releaseProfile": { "type": "string", "minLength": 1 },
    "policyDigest": { "$ref": "#/$defs/digest" },
    "createdFrom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["configPath", "sourceFiles"],
      "properties": {
        "configPath": { "$ref": "#/$defs/relativePath" },
        "sourceFiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/relativePath" }
        }
      }
    },
    "contexts": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/dotKey" },
      "additionalProperties": { "$ref": "#/$defs/context" }
    },
    "aliases": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/aliasKey" },
      "additionalProperties": { "$ref": "#/$defs/dotKey" }
    },
    "catalogDigest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "dotKey": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*(?:\\.[A-Za-z][A-Za-z0-9_-]*)*$"
    },
    "aliasKey": {
      "type": "string",
      "pattern": "^(?:[A-Za-z][A-Za-z0-9_-]*(?:\\.[A-Za-z][A-Za-z0-9_-]*)*|[A-Za-z][A-Za-z0-9_-]*:[A-Za-z][A-Za-z0-9_.-]*)$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "type", "trust", "placement", "encoding"],
      "properties": {
        "required": { "const": true },
        "type": { "enum": ["string", "number", "boolean", "json"] },
        "trust": { "enum": ["trusted", "untrusted"] },
        "placement": { "enum": ["inline", "delimited-context"] },
        "encoding": { "enum": ["raw", "json-string", "json-value"] }
      },
      "allOf": [
        {
          "not": {
            "required": ["trust", "encoding"],
            "properties": {
              "trust": { "const": "untrusted" },
              "encoding": { "const": "raw" }
            }
          }
        },
        {
          "if": { "properties": { "encoding": { "const": "raw" } }, "required": ["encoding"] },
          "then": { "properties": { "type": { "const": "string" } }, "required": ["type"] }
        },
        {
          "if": { "properties": { "encoding": { "const": "json-string" } }, "required": ["encoding"] },
          "then": { "properties": { "type": { "enum": ["string", "number", "boolean"] } }, "required": ["type"] }
        }
      ]
    },
    "segment": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "literal" },
            "value": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "name"],
          "properties": {
            "type": { "const": "variable" },
            "name": { "$ref": "#/$defs/variableName" }
          }
        }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "severity", "enforcement", "optimizable", "segments"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["instruction", "runtime-fact", "tool-contract", "output-contract", "overlay"] },
        "severity": { "enum": ["must", "should", "may"] },
        "enforcement": { "enum": ["prompt", "schema", "host"] },
        "optimizable": { "type": "boolean" },
        "segments": {
          "type": "array",
          "items": { "$ref": "#/$defs/segment" }
        }
      }
    },
    "locale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections", "artifactHash"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/section" }
        },
        "artifactHash": { "$ref": "#/$defs/digest" }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "owner",
        "contentKind",
        "sourceLocale",
        "requiredLocales",
        "variables",
        "locales",
        "definitionHash",
        "releaseDigest"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/dotKey" },
        "owner": { "type": "string", "minLength": 1 },
        "contentKind": { "const": "text" },
        "sourceLocale": { "$ref": "#/$defs/localeId" },
        "requiredLocales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/localeId" }
        },
        "variables": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/variableName" },
          "additionalProperties": { "$ref": "#/$defs/variable" }
        },
        "locales": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/localeId" },
          "additionalProperties": { "$ref": "#/$defs/locale" }
        },
        "definitionHash": { "$ref": "#/$defs/digest" },
        "releaseDigest": { "$ref": "#/$defs/digest" }
      }
    },
    "localeId": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$"
    },
    "variableName": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    }
  }
}

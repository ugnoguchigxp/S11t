{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s11t.dev/schemas/s11t-artifact-v3.schema.json",
  "title": "S11t catalog artifact v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "compilerVersion",
    "releaseProfile",
    "policyDigest",
    "renderingContract",
    "createdFrom",
    "contexts",
    "aliases",
    "catalogDigest"
  ],
  "properties": {
    "format": { "const": "s11t.catalog" },
    "schemaVersion": { "const": 3 },
    "compilerVersion": { "type": "string", "minLength": 1 },
    "releaseProfile": { "type": "string", "minLength": 1 },
    "policyDigest": { "$ref": "s11t-artifact-v2.schema.json#/$defs/digest" },
    "renderingContract": { "const": "delimited-context-v1" },
    "createdFrom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["configPath", "sourceFiles"],
      "properties": {
        "configPath": { "$ref": "s11t-artifact-v2.schema.json#/$defs/relativePath" },
        "sourceFiles": {
          "type": "array",
          "items": { "$ref": "s11t-artifact-v2.schema.json#/$defs/relativePath" }
        }
      }
    },
    "contexts": {
      "type": "object",
      "propertyNames": { "$ref": "s11t-artifact-v2.schema.json#/$defs/dotKey" },
      "additionalProperties": {
        "allOf": [
          { "$ref": "s11t-artifact-v2.schema.json#/$defs/context" },
          {
            "type": "object",
            "properties": {
              "variables": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "if": {
                    "type": "object",
                    "required": ["trust"],
                    "properties": { "trust": { "const": "untrusted" } }
                  },
                  "then": {
                    "type": "object",
                    "required": ["placement"],
                    "properties": { "placement": { "const": "delimited-context" } }
                  }
                }
              }
            }
          }
        ]
      }
    },
    "aliases": {
      "type": "object",
      "propertyNames": { "$ref": "s11t-artifact-v2.schema.json#/$defs/aliasKey" },
      "additionalProperties": { "$ref": "s11t-artifact-v2.schema.json#/$defs/dotKey" }
    },
    "catalogDigest": { "$ref": "s11t-artifact-v2.schema.json#/$defs/digest" }
  }
}

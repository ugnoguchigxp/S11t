{
  "name": "s11t",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ugnoguchigxp/S11t.git"
  },
  "homepage": "https://github.com/ugnoguchigxp/S11t#readme",
  "bugs": {
    "url": "https://github.com/ugnoguchigxp/S11t/issues"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": "^20.19.0 || ^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:schema-drift": "vitest run packages/runtime/tests/artifact-schema.test.ts packages/runtime/tests/artifact-schema-v2.test.ts packages/cli/tests/authoring-json-schema.test.ts packages/cli/tests/authoring-v2-json-schema.test.ts",
    "test:cross-node": "vitest run packages/runtime/tests/hash.test.ts packages/runtime/tests/hash-v2.test.ts",
    "test:no-node-builtins": "node scripts/check-runtime-boundary.mjs",
    "test:browser-bundle": "node scripts/check-browser-bundle.mjs",
    "test:type-fixtures": "tsc -p test-consumer/types/tsconfig.json --pretty false",
    "check:versions": "node scripts/sync-package-versions.mjs --check",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-package-versions.mjs && pnpm install --lockfile-only",
    "version:canary": "changeset version --snapshot canary && node scripts/sync-package-versions.mjs && pnpm install --lockfile-only",
    "pack:all": "node scripts/pack-all.mjs",
    "test:package-contents": "node scripts/check-package-contents.mjs",
    "test:consumer": "node scripts/test-tarball-consumer.mjs",
    "test:packages": "pnpm pack:all && pnpm test:package-contents && pnpm test:consumer",
    "release:dry-run": "node scripts/release-dry-run.mjs",
    "deploy:nightworkers-canary": "node scripts/deploy-nightworkers-canary.mjs",
    "verify": "pnpm check:versions && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:type-fixtures && pnpm test:no-node-builtins && pnpm test:browser-bundle && pnpm exec s11t --help"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@s11t/cli": "workspace:*",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "ajv": "8.20.0",
    "cross-spawn": "7.0.6",
    "esbuild": "0.28.1",
    "tar": "7.5.20",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
